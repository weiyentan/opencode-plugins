{
  "name": "@weiyentan/opencode-plugin-sqlite",
  "version": "0.1.0",
  "private": false,
  "description": "OpenCode plugin for read-only SQLite database queries.",
  "type": "module",
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.8",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^24.12.2",
    "rimraf": "^6.0.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.17.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "sqlite",
    "database"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/weiyentan/opencode-plugins",
    "directory": "packages/sqlite"
  }
}
